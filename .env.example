# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored.

# Anthropic API key (required for projection + check_compatibility + propose).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Default Claude model.
CHARTER_MODEL=claude-sonnet-4-6

# Local FastAPI base URL. Used by `charter issue` to compute the published
# charter_url. In v0 demo this is localhost; in production this would be
# https://charter.dev/
CHARTER_URL_BASE=http://localhost:8000

# Local data directory for Charter JSON files and Ed25519 issuer keys.
CHARTER_DATA_DIR=./data
