# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored.

# Anthropic API key — required only for `charter issue` (projection step).
# Fetching, verifying, and aggregating verdicts requires no API key.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic model used by the projection step.
CHARTER_MODEL=claude-sonnet-4-6

# Public base URL where Charters are hosted. Used by `charter issue` to
# compute the published charter_url. Default is the local dev host; in
# production, set this to the publicly reachable HTTPS origin.
CHARTER_URL_BASE=http://localhost:8000

# Local data directory for Charter JSON files and Ed25519 issuer keys.
CHARTER_DATA_DIR=./data
