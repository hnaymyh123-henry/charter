{
  "name": "@charter/core",
  "version": "0.9.0",
  "description": "Charter protocol core SDK for JavaScript / TypeScript — schema, canonical bytes, Ed25519 sign/verify, aggregate verdict, strict chain verification, transparency log, and SD-JWT path 1 privacy. Cross-language byte-equivalent with the Python reference implementation.",
  "license": "Apache-2.0",
  "author": "Charter contributors",
  "homepage": "https://github.com/hnaymyh123-henry/charter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hnaymyh123-henry/charter.git",
    "directory": "js"
  },
  "bugs": {
    "url": "https://github.com/hnaymyh123-henry/charter/issues"
  },
  "keywords": [
    "charter",
    "agent",
    "delegation",
    "ed25519",
    "ap2",
    "authorization",
    "protocol"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
